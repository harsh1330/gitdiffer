---
const { id, origin } = Astro.props as { id: string; origin: string };
const curl = `curl -s ${origin}/api/patches/${id}/raw | git apply -`;
const cli = `npx gitdiffer apply ${id}`;
const dl = `${origin}/api/patches/${id}/raw`;
---
<section class="card overflow-hidden">
  <header class="flex items-center justify-between px-4 py-2.5 border-b border-border2 bg-bg2/60">
    <div class="flex items-center gap-1">
      <button data-tab="curl" class="tab tab-active eyebrow px-3 py-1.5 rounded-md transition-colors">curl</button>
      <button data-tab="cli"  class="tab eyebrow px-3 py-1.5 rounded-md transition-colors">cli</button>
    </div>
    <a href={dl} download={`${id}.patch`} class="eyebrow hover:text-blue transition-colors flex items-center gap-2">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 4v12m0 0l-5-5m5 5l5-5M4 20h16"/></svg>
      .patch
    </a>
  </header>

  <div class="px-5 py-5 relative">
    <pre data-pane="curl" class="font-mono text-[13px] leading-[1.7] whitespace-pre-wrap break-all text-ink"><span class="text-muted mr-2">$</span>{curl}</pre>
    <pre data-pane="cli"  class="font-mono text-[13px] leading-[1.7] whitespace-pre-wrap break-all hidden text-ink"><span class="text-muted mr-2">$</span>{cli}</pre>

    <div class="mt-4 flex items-center gap-3">
      <button id="copy-cmd" class="btn-ghost rounded-md px-3 py-1.5 inline-flex items-center gap-2">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="8" y="8" width="13" height="13" rx="1.5"/><path d="M16 8V5a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h3"/></svg>
        copy
      </button>
      <span id="copy-status" class="eyebrow text-green"></span>
    </div>
  </div>
</section>

<style>
  .tab {
    color: var(--muted);
    background: transparent;
  }
  .tab:hover { color: var(--ink); }
  .tab-active {
    background: linear-gradient(135deg, rgba(88,166,255,0.18), rgba(188,140,255,0.18));
    color: var(--ink) !important;
    box-shadow: inset 0 0 0 1px rgba(88,166,255,0.35);
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".tab");
  const panes = document.querySelectorAll<HTMLPreElement>("[data-pane]");
  let active: "curl" | "cli" = "curl";
  tabs.forEach((btn) =>
    btn.addEventListener("click", () => {
      active = (btn.dataset.tab as "curl" | "cli") ?? "curl";
      tabs.forEach((b) => b.classList.toggle("tab-active", b.dataset.tab === active));
      panes.forEach((p) => p.classList.toggle("hidden", p.dataset.pane !== active));
    }),
  );
  document.getElementById("copy-cmd")?.addEventListener("click", async () => {
    const text = document.querySelector<HTMLPreElement>(`[data-pane="${active}"]`)?.textContent ?? "";
    try {
      await navigator.clipboard.writeText(text.replace(/^\$\s*/, ""));
      const status = document.getElementById("copy-status");
      if (status) {
        status.textContent = "✓ copied";
        setTimeout(() => (status.textContent = ""), 1500);
      }
    } catch {
      /* clipboard not available */
    }
  });
</script>
