---
import Base from "../layouts/Base.astro";
import PatchForm from "../components/PatchForm.astro";
import OpenPatchInput from "../components/OpenPatchInput.astro";
---
<Base title="gitdiffer — share a git diff">

  <!-- ================== HERO ================== -->
  <section class="relative pt-6 pb-16 sm:pt-12 sm:pb-24 md:pt-16 md:pb-32 text-center overflow-hidden">

    <!-- Decorative orbs -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-0">
      <div class="absolute -top-24 sm:-top-32 left-1/2 -translate-x-1/2 w-[500px] sm:w-[700px] md:w-[900px] aspect-square rounded-full opacity-40 blur-3xl"
           style="background: radial-gradient(closest-side, rgba(88,166,255,0.35), transparent 70%);"></div>
      <div class="absolute top-32 -left-40 w-[260px] sm:w-[420px] aspect-square rounded-full opacity-50 blur-3xl"
           style="background: radial-gradient(closest-side, rgba(188,140,255,0.30), transparent 70%);"></div>
      <div class="absolute top-10 -right-40 w-[260px] sm:w-[380px] aspect-square rounded-full opacity-50 blur-3xl"
           style="background: radial-gradient(closest-side, rgba(214,112,214,0.25), transparent 70%);"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto rise rise-1">
      <span class="chip mb-5 sm:mb-7">
        <span class="dot-pulse bg-blue"></span>
        no branch · no PR · just a link
      </span>

      <h1 class="display text-[38px] sm:text-[64px] md:text-[100px] lg:text-[140px] tracking-tightest leading-[0.95]">
        Send a <span class="display-italic text-gradient-blue">patch</span>,
      </h1>
      <h1 class="display text-[38px] sm:text-[64px] md:text-[100px] lg:text-[140px] tracking-tightest leading-[0.95] -mt-1 md:-mt-3">
        not a <span class="display-italic">branch</span>.
      </h1>

      <p class="mt-6 sm:mt-8 md:mt-10 text-[14px] sm:text-[15px] md:text-[16px] text-muted max-w-xl mx-auto leading-relaxed px-2">
        Paste a <code class="text-blue bg-panel border border-border2 px-1.5 py-0.5 rounded">git diff</code>,
        get a private URL. Your teammate applies it with one command —
        no push, no PR, no Slack screenshots.
      </p>

      <div class="mt-7 sm:mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href="#compose" class="btn-primary rounded-md px-5 py-3 sm:px-7 sm:py-3.5 text-[11px] sm:text-[12px] inline-flex items-center gap-3 uppercase tracking-wider">
          <span>compose a patch</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#how" class="btn-ghost rounded-md px-4 py-3 sm:px-5 sm:py-3.5 inline-flex items-center gap-2">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          how it works
        </a>
      </div>
    </div>

    <!-- Floating mock result card -->
    <div class="relative z-10 max-w-3xl mx-auto mt-12 sm:mt-16 md:mt-24 rise rise-3" aria-hidden="true">
      <div class="relative sm:rotate-[-1deg] sm:hover:rotate-0 transition-transform duration-700">
        <div class="card overflow-hidden shadow-[0_30px_60px_-20px_rgba(99,102,241,0.4),0_15px_40px_-15px_rgba(214,112,214,0.3)] sm:shadow-[0_50px_120px_-30px_rgba(99,102,241,0.45),0_30px_80px_-30px_rgba(214,112,214,0.35)]">
          <!-- Faux browser bar -->
          <div class="flex items-center gap-2 px-3 sm:px-4 py-2 sm:py-2.5 bg-bg2 border-b border-border2">
            <span class="size-2 sm:size-2.5 rounded-full bg-red/70"></span>
            <span class="size-2 sm:size-2.5 rounded-full bg-amber/70"></span>
            <span class="size-2 sm:size-2.5 rounded-full bg-green/70"></span>
            <div class="flex-1 ml-2 sm:ml-3 min-w-0">
              <div class="bg-panel border border-border2 rounded-md px-2 sm:px-3 py-1 text-[10px] sm:text-[11px] text-muted text-center font-mono truncate">
                gitdiffer.app/p/h7K9mPq2vN3xR8tB4cYwLs
              </div>
            </div>
          </div>

          <!-- Mock viewer header -->
          <div class="p-4 sm:p-6 md:p-8 text-left">
            <div class="flex items-start justify-between flex-wrap gap-3 sm:gap-4">
              <div class="min-w-0">
                <div class="eyebrow mb-1 sm:mb-2 text-blue">— dispatch —</div>
                <div class="display text-[26px] sm:text-[36px] md:text-[44px] tracking-tightest">
                  Patch <span class="display-italic text-gradient-blue">№h7K9mP</span>
                </div>
              </div>
              <div class="flex items-center gap-3 flex-wrap">
                <div class="inline-flex items-center gap-2 eyebrow">
                  <span class="size-1.5 rounded-full bg-green inline-block" style="box-shadow: 0 0 8px rgba(63,185,80,0.7);"></span>
                  expires in 7d
                </div>
                <div class="inline-flex items-center gap-2 eyebrow">
                  <span class="text-green">+42</span>
                  <span class="text-muted2">·</span>
                  <span class="text-red">−7</span>
                </div>
              </div>
            </div>

            <!-- Mock command box -->
            <div class="mt-4 sm:mt-6 bg-bg2 border border-border2 rounded-md p-3 sm:p-4 font-mono text-[11px] sm:text-[13px] overflow-x-auto">
              <div class="text-muted text-[10px] sm:text-[11px] tracking-widest2 uppercase mb-2">apply</div>
              <div class="text-ink whitespace-nowrap">
                <span class="text-muted">$</span> curl -s gitdiffer.app/api/patches/h7K9mP/raw | git apply -
              </div>
            </div>

            <!-- Mock mini diff -->
            <div class="mt-3 sm:mt-4 bg-bg2 border border-border2 rounded-md overflow-hidden font-mono text-[11px] sm:text-[12px] leading-[1.7]">
              <div class="px-3 sm:px-4 py-2 border-b border-border2 text-muted text-[10px] sm:text-[11px] tracking-wider">src/lib/auth.ts</div>
              <div class="px-3 sm:px-4 py-3 space-y-1 overflow-x-auto">
                <div class="text-muted2 whitespace-nowrap">  function login(user) {`{`}</div>
                <div class="bg-delBg text-delInk -mx-3 sm:-mx-4 px-3 sm:px-4 whitespace-nowrap">- &nbsp;return token(user);</div>
                <div class="bg-addBg text-addInk -mx-3 sm:-mx-4 px-3 sm:px-4 whitespace-nowrap">+ &nbsp;return signedToken(user, exp);</div>
                <div class="bg-addBg text-addInk -mx-3 sm:-mx-4 px-3 sm:px-4 whitespace-nowrap">+ &nbsp;telemetry.tag("auth.login");</div>
                <div class="text-muted2 whitespace-nowrap">  {`}`}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- floating tag (desktop only) -->
        <div class="absolute -top-4 -right-4 hidden md:block">
          <div class="chip" style="background: rgba(63,185,80,0.10); border-color: rgba(63,185,80,0.4); color: var(--green);">
            <span class="dot-pulse bg-green"></span>
            link copied
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================== HOW IT WORKS ================== -->
  <section id="how" class="relative py-14 sm:py-20 md:py-28">
    <div class="text-center mb-10 sm:mb-14 rise rise-1">
      <p class="eyebrow mb-3">— how it works —</p>
      <h2 class="display text-[32px] sm:text-[44px] md:text-[64px] tracking-tightest leading-[1.05]">
        From paste to <span class="display-italic text-gradient-blue">apply</span> in seconds.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      <div class="card p-5 sm:p-7 hover:-translate-y-1 hover:border-blue/40 transition-all duration-300 rise rise-2">
        <div class="flex items-center justify-between mb-4 sm:mb-5">
          <span class="font-mono text-[11px] tracking-widest2 text-blue">01</span>
          <div class="size-9 sm:size-10 rounded-md flex items-center justify-center bg-blue/10 border border-blue/30 text-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
          </div>
        </div>
        <h3 class="display text-[24px] sm:text-[28px] tracking-tightest mb-2">Compose</h3>
        <p class="text-muted text-[13px] leading-relaxed">
          Paste the output of <code class="text-blue">git diff</code>, drag in a <code class="text-blue">.patch</code> file, or pipe from your shell.
        </p>
      </div>

      <div class="card p-5 sm:p-7 hover:-translate-y-1 hover:border-purple/40 transition-all duration-300 rise rise-3">
        <div class="flex items-center justify-between mb-4 sm:mb-5">
          <span class="font-mono text-[11px] tracking-widest2 text-purple">02</span>
          <div class="size-9 sm:size-10 rounded-md flex items-center justify-center bg-purple/10 border border-purple/30 text-purple">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12l20-9-7 20-3-9-10-2z"/></svg>
          </div>
        </div>
        <h3 class="display text-[24px] sm:text-[28px] tracking-tightest mb-2">Dispatch</h3>
        <p class="text-muted text-[13px] leading-relaxed">
          We mint a private, unguessable URL and copy it to your clipboard. Set an expiry — it self-destructs after.
        </p>
      </div>

      <div class="card p-5 sm:p-7 hover:-translate-y-1 hover:border-magenta/40 transition-all duration-300 rise rise-4">
        <div class="flex items-center justify-between mb-4 sm:mb-5">
          <span class="font-mono text-[11px] tracking-widest2 text-magenta">03</span>
          <div class="size-9 sm:size-10 rounded-md flex items-center justify-center bg-magenta/10 border border-magenta/30 text-magenta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
        </div>
        <h3 class="display text-[24px] sm:text-[28px] tracking-tightest mb-2">Apply</h3>
        <p class="text-muted text-[13px] leading-relaxed">
          Recipient runs the curl one-liner, or <code class="text-magenta">npx gitdiffer apply &lt;id&gt;</code>. Done.
        </p>
      </div>
    </div>
  </section>

  <!-- ================== COMPOSE ================== -->
  <section id="compose" class="relative py-14 sm:py-20 md:py-28 scroll-mt-20">
    <div class="text-center mb-8 sm:mb-12 rise rise-1">
      <p class="eyebrow mb-3">— compose —</p>
      <h2 class="display text-[32px] sm:text-[44px] md:text-[64px] tracking-tightest leading-[1.05]">
        Drop your <span class="display-italic text-gradient-blue">diff</span>.
      </h2>
      <p class="text-muted text-[13px] sm:text-[14px] mt-3 max-w-md mx-auto px-4">
        Up to 1 MB. Default expiry 7 days. No login required.
      </p>
    </div>

    <div class="max-w-4xl mx-auto rise rise-2">
      <PatchForm />
    </div>

    <!-- Open existing patch -->
    <div class="max-w-md mx-auto mt-12 sm:mt-16 rise rise-3">
      <OpenPatchInput />
    </div>
  </section>

  <!-- ================== FEATURE HIGHLIGHTS ================== -->
  <section class="relative py-14 sm:py-20 md:py-28">
    <div class="text-center mb-10 sm:mb-14 rise rise-1">
      <p class="eyebrow mb-3">— what makes it small but sharp —</p>
      <h2 class="display text-[30px] sm:text-[40px] md:text-[56px] tracking-tightest leading-[1.05] max-w-3xl mx-auto">
        Tiny tool. <span class="display-italic">Surprisingly thoughtful.</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">

      <div class="card p-5 sm:p-6 hover:border-blue/30 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <div class="size-8 rounded-md flex items-center justify-center bg-blue/10 border border-blue/30 text-blue shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l9 4v6c0 5-3.5 9-9 10-5.5-1-9-5-9-10V6l9-4z"/></svg>
          </div>
          <h4 class="font-mono text-[13px]">Private by default</h4>
        </div>
        <p class="text-muted text-[12.5px] leading-relaxed">131-bit unguessable URLs. Only people you send the link to can read or apply.</p>
      </div>

      <div class="card p-5 sm:p-6 hover:border-amber/30 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <div class="size-8 rounded-md flex items-center justify-center bg-amber/10 border border-amber/30 text-amber shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h4 class="font-mono text-[13px]">Self-expiring</h4>
        </div>
        <p class="text-muted text-[12.5px] leading-relaxed">Pick 1h, 24h, 7d, or 30d. Patches delete themselves — no cleanup needed.</p>
      </div>

      <div class="card p-5 sm:p-6 hover:border-purple/30 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <div class="size-8 rounded-md flex items-center justify-center bg-purple/10 border border-purple/30 text-purple shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17l6-6-6-6"/><path d="M12 19h8"/></svg>
          </div>
          <h4 class="font-mono text-[13px]">Zero-install CLI</h4>
        </div>
        <p class="text-muted text-[12.5px] leading-relaxed"><code class="text-purple">npx gitdiffer</code> works without installing anything globally.</p>
      </div>

      <div class="card p-5 sm:p-6 hover:border-green/30 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <div class="size-8 rounded-md flex items-center justify-center bg-green/10 border border-green/30 text-green shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h4 class="font-mono text-[13px]">One-line apply</h4>
        </div>
        <p class="text-muted text-[12.5px] leading-relaxed">Recipient pastes a curl one-liner. No account, no app to install.</p>
      </div>

      <div class="card p-5 sm:p-6 hover:border-magenta/30 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <div class="size-8 rounded-md flex items-center justify-center bg-magenta/10 border border-magenta/30 text-magenta shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </div>
          <h4 class="font-mono text-[13px]">Side-by-side diff</h4>
        </div>
        <p class="text-muted text-[12.5px] leading-relaxed">Beautifully rendered file-by-file diff in the browser before applying.</p>
      </div>

      <div class="card p-5 sm:p-6 hover:border-red/30 transition-colors">
        <div class="flex items-center gap-3 mb-3">
          <div class="size-8 rounded-md flex items-center justify-center bg-red/10 border border-red/30 text-red shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h4 class="font-mono text-[13px]">Edge-fast</h4>
        </div>
        <p class="text-muted text-[12.5px] leading-relaxed">Hosted on Netlify with edge functions. Sub-second roundtrip from anywhere.</p>
      </div>

    </div>
  </section>

  <!-- ================== TERMINAL SHOWCASE ================== -->
  <section class="relative py-14 sm:py-20 md:py-28">
    <div class="text-center mb-10 sm:mb-14 rise rise-1">
      <p class="eyebrow mb-3">— or skip the form —</p>
      <h2 class="display text-[30px] sm:text-[40px] md:text-[56px] tracking-tightest leading-[1.05]">
        Live in the <span class="display-italic text-gradient-blue">terminal</span>.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-4 sm:gap-5 max-w-5xl mx-auto">
      <div class="card overflow-hidden rise rise-2">
        <div class="flex items-center gap-2 px-3 sm:px-4 py-2 sm:py-2.5 border-b border-border2 bg-bg2">
          <span class="size-2 sm:size-2.5 rounded-full bg-red/70"></span>
          <span class="size-2 sm:size-2.5 rounded-full bg-amber/70"></span>
          <span class="size-2 sm:size-2.5 rounded-full bg-green/70"></span>
          <span class="eyebrow ml-2 sm:ml-3">your machine</span>
        </div>
        <pre class="p-4 sm:p-5 text-[12px] sm:text-[13px] leading-[1.7] overflow-x-auto"><span class="text-muted">$</span> <span class="text-ink">npx gitdiffer share</span>
<span class="text-green">  ✓ Patch shared (expires in 7d)</span>
<span class="text-blue">    https://&hellip;/p/h7K9mPq2vN3xR8tB4cYwLs</span>
<span class="text-muted">    (copied to clipboard)</span></pre>
      </div>
      <div class="card overflow-hidden rise rise-3">
        <div class="flex items-center gap-2 px-3 sm:px-4 py-2 sm:py-2.5 border-b border-border2 bg-bg2">
          <span class="size-2 sm:size-2.5 rounded-full bg-red/70"></span>
          <span class="size-2 sm:size-2.5 rounded-full bg-amber/70"></span>
          <span class="size-2 sm:size-2.5 rounded-full bg-green/70"></span>
          <span class="eyebrow ml-2 sm:ml-3">their machine</span>
        </div>
        <pre class="p-4 sm:p-5 text-[12px] sm:text-[13px] leading-[1.7] overflow-x-auto"><span class="text-muted">$</span> <span class="text-ink">npx gitdiffer apply h7K9mPq2vN3xR8tB4cYwLs</span>
<span class="text-green">  ✓ Applied 3 files (+42 −7)</span>
<span class="text-muted">  Working tree updated.</span></pre>
      </div>
    </div>
  </section>

  <!-- ================== FINAL CTA ================== -->
  <section class="relative py-16 sm:py-24 md:py-32 text-center">
    <div class="max-w-2xl mx-auto rise rise-1">
      <h2 class="display text-[36px] sm:text-[48px] md:text-[80px] tracking-tightest leading-[1.05]">
        Ready to <span class="display-italic text-gradient-blue">dispatch</span>?
      </h2>
      <p class="text-muted mt-4 sm:mt-5 text-[14px] sm:text-[15px] px-4">
        Your next code review can be a single link, not a branch nobody asked for.
      </p>
      <a href="#compose" class="btn-primary rounded-md px-6 py-3.5 sm:px-8 sm:py-4 mt-7 sm:mt-9 inline-flex items-center gap-3 text-[11px] sm:text-[12px] uppercase tracking-wider">
        compose your first patch
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

</Base>
